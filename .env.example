# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=1024

# ── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL en el dashboard
SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (nuevo formato sb_publishable_*)
SUPABASE_ANON_KEY=
# Settings > API > service_role  ← necesario para operaciones admin (bypasa RLS)
# Dejar vacío en desarrollo; el backend usa SUPABASE_ANON_KEY como fallback
SUPABASE_SERVICE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# Lista separada por comas, sin espacios
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Scheduler (reactivación nocturna — hora UTC) ──────────────────────────────
# 02:00 Lima (UTC-5) = 07:00 UTC
REACTIVATION_CRON_HOUR=7
REACTIVATION_CRON_MINUTE=0
INACTIVITY_THRESHOLD_DAYS=30
